    <DTS:Executable
      DTS:refId="Package\Execute SQL Task - Load DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{2426047E-958B-43D4-A0A1-C9A30346E39A}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task - Load DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E3F6BEAA-C2D3-4A3C-AE59-5937726988B7}"
          SQLTask:SqlStatementSource="INSERT INTO DimDate (DateKey, FullDate, DayNumber, MonthNumber, MonthName, QuarterNumber, YearNumber)&#xA;SELECT DISTINCT&#xA;    CAST(CONVERT(VARCHAR(8), [Date], 112) AS INT) AS DateKey,&#xA;    [Date] AS FullDate,&#xA;    DAY([Date]) AS DayNumber,&#xA;    MONTH([Date]) AS MonthNumber,&#xA;    DATENAME(MONTH, [Date]) AS MonthName,&#xA;    DATEPART(QUARTER, [Date]) AS QuarterNumber,&#xA;    YEAR([Date]) AS YearNumber&#xA;FROM Healthcare_Staging.dbo.StgAppointment s&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1&#xA;    FROM Healthcare_DW.dbo.DimDate d&#xA;    WHERE d.FullDate = s.[Date]&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
